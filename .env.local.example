# MoonTurtle local configuration

# Model selection for Phase 1 provider routing.
# Examples:
# MT_MODEL=claude-opus-4-7
# MT_MODEL=gpt-5.5
MT_MODEL=claude-opus-4-7
VITE_MOONTURTLE_USE_PROVIDER=auto
MOONTURTLE_LOCAL_PROVIDER=auto

# Direct hosted provider keys for local Worker/dev use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Localhost mode uses logged-in CLI subscriptions when available.
# auto = Codex first, then Claude. Other choices: codex, claude.
